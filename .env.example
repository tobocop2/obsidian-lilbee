# Environment variables lilbee for Obsidian reads from your OS environment.
# The plugin does not load this file automatically; it documents the supported
# variables. Set them in your shell before launching Obsidian.

# Override where lilbee stores the server binary, models, and the search index.
# Defaults to your OS data directory (XDG_DATA_HOME / LOCALAPPDATA / ~/.local/share).
LILBEE_DATA=/path/to/lilbee-data
