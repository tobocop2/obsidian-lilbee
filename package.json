{
  "name": "obsidian-lilbee",
  "version": "0.6.82",
  "private": true,
  "description": "A local AI search engine and model manager for your Obsidian vault: ask your notes, PDFs, code, and crawled web pages in plain English and get answers with citations. Local-first, with a built-in model catalog. Works with Ollama and LM Studio.",
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "local-ai",
    "ai-search-engine",
    "rag",
    "retrieval-augmented-generation",
    "semantic-search",
    "llm",
    "web-crawler",
    "cited-answers",
    "ollama",
    "lm-studio",
    "mcp"
  ],
  "homepage": "https://obsidian.lilbee.sh/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tobocop2/obsidian-lilbee.git"
  },
  "bugs": {
    "url": "https://github.com/tobocop2/obsidian-lilbee/issues"
  },
  "license": "MIT",
  "author": "Tobias Perelstein",
  "scripts": {
    "build": "node esbuild.config.mjs production",
    "dev": "node esbuild.config.mjs",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "prepare": "husky",
    "lint:store": "eslint --config eslint.obsidian.mjs src"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.9",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-obsidianmd": "^0.4.0",
    "husky": "^9.1.7",
    "nano-staged": "^1.0.2",
    "obsidian": "^1.13.1",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  },
  "nano-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "tests/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "fflate": "^0.8.3"
  }
}
